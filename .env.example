# app
NEXT_PUBLIC_APP_URL = "https://seedvr2.ai"
NEXT_PUBLIC_APP_NAME = "SeedVR2"

# theme
NEXT_PUBLIC_THEME = "default"

# appearance
NEXT_PUBLIC_APPEARANCE = "system"

# database
DATABASE_PROVIDER = "postgresql"
DATABASE_URL = ""
DB_SINGLETON_ENABLED = "true"
DB_MAX_CONNECTIONS = "1"

# auth secret
# openssl rand -base64 32
AUTH_SECRET = ""

# ============================================
# Aliyun OSS Storage (for video upload)
# ============================================
# Get credentials from: https://ram.console.aliyun.com/
# Region example: oss-cn-hangzhou, oss-cn-shanghai, oss-ap-southeast-1
ALIYUN_OSS_REGION = ""
ALIYUN_OSS_ACCESS_KEY_ID = ""
ALIYUN_OSS_ACCESS_KEY_SECRET = ""
ALIYUN_OSS_BUCKET = ""
# Optional: Custom domain for public access (e.g., https://cdn.seedvr2.ai)
ALIYUN_OSS_PUBLIC_DOMAIN = ""

# ============================================
# SeedVR2 Video Restoration API (Replicate)
# ============================================
# Get your API token from: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN = ""
# Optional: Custom API URL (default: https://api.replicate.com/v1)
REPLICATE_API_URL = ""
# Model: zsxkib/seedvr2
# Docs: https://replicate.com/zsxkib/seedvr2